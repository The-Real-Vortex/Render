@page "/create-post"
@using Render.Client.Models
@using Render.Client.State
@using System.ComponentModel.DataAnnotations
@using MudBlazor.Components
@using System.Linq
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject CreatePostState State

<style>
    .file-upload-input {
        position: absolute;
        width: 100%;
        height: 100%;
        overflow: hidden;
        z-index: 10;
        opacity: 0;
        cursor: pointer;
    }
</style>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-16">
    <MudForm @bind-IsValid="_formIsValid" @ref="_form">
        <MudCard Elevation="3">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h5" Color="Color.Primary" Align="Align.Center">Create Post</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>

                <MudTextField T="string" Label="Content" Variant="Variant.Outlined"
                              @bind-Value="State.PostModel.Content" For="@(() => State.PostModel.Content)"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.TextFields"
                              Immediate="true" Validation="@((string c) => ValidateContent(c))" />

                <MudFileUpload T="IBrowserFile"
                               FilesChanged="UploadFiles"
                               @ref="@_fileUpload"
                               Hidden="false"
                               InputClass="file-upload-input"
                               Accept=".png,.jpg,.jpeg,.gif,.webp"
                               tabindex="-1"
                               @ondrop="@ClearDragClass"
                               @ondragenter="@SetDragClass"
                               @ondragleave="@ClearDragClass"
                               @ondragend="@ClearDragClass">
                    <ActivatorContent>
                        <MudPaper Outlined="true"
                                  Class="@_dragClass"
                                  Style="min-height: 300px; cursor: pointer; position: relative;">

                            @if (_files != null && _files.Count > 0 && State.PostModel.ImageBytes?.Length > 0)
                            {
                                <MudImage Src="@($"data:image/png;base64,{Convert.ToBase64String(State.PostModel.ImageBytes)}")"
                                          Alt="Selected Image"
                                          Style="width: 100%; max-height: 600px; object-fit: contain;" />
                            }
                            else
                            {
                                <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="height: 100%;">
                                    <MudIcon Icon="@Icons.Material.Filled.CloudUpload" Size="Size.Large" Color="Color.Secondary" />
                                    <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mt-2">
                                        Drag and drop an image here or click to browse
                                    </MudText>
                                </MudStack>
                            }
                        </MudPaper>
                    </ActivatorContent>
                </MudFileUpload>

                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                    @if (_files != null && _files.Count > 0)
                    {
                        <div>Selected file: @_files.First().Name (@(_files.First().Size / 1024) KB)</div>
                    }
                    else
                    {
                        <div>No file selected</div>
                    }
                </MudText>
            </MudCardContent>
            <MudCardActions>
                <MudButton Variant="Variant.Filled" Color="Color.Secondary" FullWidth="true" href="/">
                    Cancel
                </MudButton>
                <MudSpacer />
                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                           OnClick="State.CreatePostAsync" Disabled="@(!_formIsValid || ( (State.PostModel.ImageBytes == null || State.PostModel.ImageBytes.Length == 0) && string.IsNullOrWhiteSpace(State.PostModel.Content) ))">
                    Create Post
                </MudButton>
            </MudCardActions>
        </MudCard>
    </MudForm>
</MudContainer>

@code {
private static readonly HashSet<string> _allowedExtensions =
    new(StringComparer.OrdinalIgnoreCase) { ".png", ".jpg", ".jpeg", ".gif", ".webp" };
private const long MaxFileSizeBytes = 5 * 1024 * 1024;

bool _formIsValid = false;
private MudForm _form = default!;
private const string DefaultDragClass = "d-flex flex-column align-center justify-center rounded-lg border-2 border-dashed pa-4 mt-4";
private string _dragClass = DefaultDragClass;
private MudFileUpload<IBrowserFile>? _fileUpload;
IList<IBrowserFile> _files = new List<IBrowserFile>();

private string? ValidateContent(string content)
{
    bool hasImage = State.PostModel.ImageBytes?.Length > 0;
    if (!hasImage && string.IsNullOrWhiteSpace(content))
        return "Content is required when no image is uploaded.";
    if (!string.IsNullOrWhiteSpace(content) && content.Length < 10)
        return "Content must be at least 10 characters long.";
    if (content?.Length > 3500)
        return "Content must not exceed 3500 characters.";
    return null;
}

private async Task UploadFiles(IBrowserFile file)
{
    var extension = Path.GetExtension(file.Name);
    if (!_allowedExtensions.Contains(extension))
    {
        Snackbar.Add("Only image files (.png, .jpg, .jpeg, .gif, .webp) are allowed.", Severity.Error);
        return;
    }

    if (file.Size > MaxFileSizeBytes)
    {
        Snackbar.Add("File size must not exceed 5 MB.", Severity.Error);
        return;
    }

    _files.Clear();
    _files.Add(file);

    using var stream = file.OpenReadStream(maxAllowedSize: MaxFileSizeBytes);
    using var ms = new MemoryStream();
    await stream.CopyToAsync(ms);
    State.PostModel.ImageBytes = ms.ToArray();
    ClearDragClass();
    await _form.Validate();
}

    private void SetDragClass()
        => _dragClass = $"{DefaultDragClass} mud-border-primary";

    private void ClearDragClass()
        => _dragClass = DefaultDragClass;
}